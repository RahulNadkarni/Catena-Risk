# Catena Telematics API (copy to .env.local — never commit .env.local)
#
# Scripts (`npm run explore:api`, `npm run seed:fixtures`) load `.env` then `.env.local` via
# scripts/load-env.ts — same credentials you use here are used by those commands.
#
# Sandbox note (from Catena): subscribing to webhooks for the Sandbox fleet will not work
# the way that fleet is hydrated (it bypasses EDA). Prefer REST polling / exploration for Phase 0.
# Webhook subscription endpoints remain in the coverage report for completeness, not as a sandbox demo path.

# API host (production default; use Catena-provided sandbox host if different)
CATENA_BASE_URL=https://api.catenatelematics.com

# Keycloak realm base (no trailing slash); token path is /protocol/openid-connect/token
CATENA_AUTH_BASE_URL=https://auth.catenatelematics.com/realms/catena

# OAuth2 client credentials (required unless CATENA_ACCESS_TOKEN is set)
CATENA_CLIENT_ID=
CATENA_CLIENT_SECRET=

# Optional: skip token exchange (e.g. short-lived bearer from your tooling)
# CATENA_ACCESS_TOKEN=

# Optional: only if your environment documents API-key auth (not in public OpenAPI auth spec)
# CATENA_API_KEY=

# Verbose client logging (request URL, params, response shape)
# CATENA_DEBUG=1
