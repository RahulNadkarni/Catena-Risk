{
  "name": "catena-risk",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.17.0"
  },
  "overrides": {
    "next": "14.2.35",
    "@next/env": "14.2.35"
  },
  "scripts": {
    "postinstall": "node scripts/apply-next-semver-patch.mjs",
    "dev": "node ./node_modules/next/dist/bin/next dev",
    "build": "node ./node_modules/next/dist/bin/next build",
    "start": "node ./node_modules/next/dist/bin/next start",
    "lint": "node ./node_modules/next/dist/bin/next lint",
    "explore:api": "npx tsx scripts/explore-api.ts",
    "seed:fixtures": "npx tsx scripts/seed-fixtures.ts",
    "inspect:fleet": "npx tsx scripts/inspect-fleet.ts",
    "score:fleet": "npx tsx scripts/score-fleet.ts",
    "seed:claims": "npx tsx scripts/seed-claims.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@tanstack/react-table": "^8.21.3",
    "axios": "^1.15.0",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.8.0",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "react-leaflet": "^4.2.1",
    "recharts": "^3.8.1",
    "shadcn": "^4.3.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
